# ── Client (Vite — public, bundled into browser) ──
# Mirror SUPABASE_URL / anon key here for browser auth (see npm run setup:local)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Server secrets (Vercel / .env.local — never expose to client) ──
GEMINI_API_KEY=
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Auth & admin
AUTH_ENFORCE=true
AUTH_AUTO_APPROVE=true
AUTH_SITE_URL=https://wallpilot.vercel.app
BOOTSTRAP_ADMIN_EMAIL=you@example.com

# Google OAuth — Vercel env + Supabase Dashboard Google provider (same Client ID/Secret)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_AUTH_REDIRECT_URI=https://wallpilot.vercel.app/auth/callback

# Stripe subscriptions
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BASIC=
STRIPE_PRICE_PRO=
STRIPE_PRICE_PREMIUM=
STRIPE_PRICE_ELITE=

# Danal (KR card payments — Phase 3)
DANAL_CLIENT_ID=
DANAL_CLIENT_SECRET=

# Email notifications (Phase 2)
RESEND_API_KEY=

# Vercel one-click env save (My API panels)
VERCEL_ACCESS_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=
WALLPILOT_SETUP_SECRET=

# Market data & integrations
FMP_API_KEY=
ALPHA_VANTAGE_API_KEY=
TOSS_API_BASE_URL=https://openapi.tossinvest.com
KOREA_STOCK_MCP_URL=https://korea-stock-analyzer-mcp.vercel.app
TRADINGAGENTS_SERVICE_URL=
